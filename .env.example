# GraphQL: use /graphql so the browser hits Next, which proxies to your Nest API (see GRAPHQL_PROXY_TARGET).
NEXT_PUBLIC_GRAPHQL_URL=/graphql
GRAPHQL_PROXY_TARGET=http://127.0.0.1:3007

# Telegram / ngrok: public HTTPS URL of THIS Next app (for broadcast image links). Often auto-detected from request.
# PUBLIC_APP_URL=https://your-subdomain.ngrok-free.app

# Broadcast images: leave empty to save under public/uploads on this server.
UPLOAD_PROXY_URL=
